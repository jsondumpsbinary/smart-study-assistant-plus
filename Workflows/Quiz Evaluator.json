      "parameters": {
        "promptType": "define",
        "text": "=You are grading an exam on '{{ $json.body.topic }}'. Evaluate the user answers: {{ JSON.stringify($json.body.answers) }}.\nOutput ONLY valid JSON matching this exact structure:\n{\n  \"score\": integer_0_to_100,\n  \"weakTopics\": [\"List\", \"Of\", \"Subtopics\"],\n  \"suggestions\": \"Actionable feedback\",\n  \"results\": [\n    {\n      \"isCorrect\": true_or_false,\n      \"explanation\": \"Short 1-2 sentence explanation of why it is right or wrong and what the correct answer is.\"\n    }\n  ]\n}\nThe 'results' array must have the exact same length and order as the user's 'answers' array. DO NOT wrap the output in markdown code blocks.",
        "batching": {}
      },
