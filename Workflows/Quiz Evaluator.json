      "name": "Grade Submission"
    },
    {
      "parameters": {
        "jsCode": "const safeParse = (nodeData) => {\n  if (!nodeData) return {};\n  const rawText = nodeData.json.text || nodeData.json.output || nodeData.json.message?.content || nodeData.json.content?.parts?.[0]?.text || '';\n  const cleaned = rawText.replace(/```json/gi, '').replace(/```/g, '').trim();\n  try {\n    return JSON.parse(cleaned);\n  } catch (e) {\n    return {};\n  }\n};\n\nconst parsed = safeParse($item(0).$node['Grade Submission']);\nconst body = $('Evaluate Webhook').item.json.body || {};\n\nreturn {\n  score: parsed.score || 0,\n  weakTopics: parsed.weakTopics || [],\n  suggestions: parsed.suggestions || '',\n  results: parsed.results || [],\n  topic: body.topic || 'Unknown Topic',\n  username: body.username || 'guest',\n  email: body.email || '',\n  lastAttempt: new Date().toISOString()\n};"
      },
